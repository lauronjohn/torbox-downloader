{
  "name": "torbox-downloader",
  "version": "1.1.1",
  "description": "Search movies, find torrents via Torrentio, download through TorBox",
  "main": "./out/main/index.js",
  "author": "John Lauron",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lauronjohn/torbox-downloader.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck:node": "tsc -p tsconfig.node.json",
    "typecheck:web": "tsc -p tsconfig.web.json",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web && npm run typecheck:test",
    "test": "node --import tsx --test test/*.test.ts",
    "generate-icons": "node scripts/generate-icons.mjs",
    "package": "electron-vite build && electron-builder --mac --linux"
  },
  "dependencies": {
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.23.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.0"
  }
}
